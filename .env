# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, zero config — file created automatically)
DATABASE_URL=sqlite+aiosqlite:///./franchise.db
# PostgreSQL (uncomment for production)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/franchise_db

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── SMTP (Gmail example) ──────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your@gmail.com

# ── Twilio (optional) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=5

# ── Super Admin (seeded automatically on first startup) ───────────────────────
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=Admin@1
SUPER_ADMIN_NAME=Super Admin

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Franchise Management System
APP_VERSION=1.0.0
DEBUG=True
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
